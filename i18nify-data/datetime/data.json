      "year_index": 1,
      "month_index": 2,
      "day_index": 3,
      "format": "YYYY.MM.DD"
    },
    {
      "regex": "^(\\d{2})-(0[1-9]|1[0-2])-(\\d{4})$",
      "year_index": 3,
      "month_index": 2,
      "day_index": 1,
      "format": "DD-MM-YYYY"
    },
    {

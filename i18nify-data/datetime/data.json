  "supported_date_formats": [
    {
      "regex": "^(\\d{4})/(0[1-9]|1[0-2])/(\\d{2})$",
      "year_index": 1,
      "month_index": 2,
      "day_index": 3,
      "format": "YYYY/MM/DD"
